---
import Layout from "../layouts/Layout.astro";
import { getTierListEntries, type Tier, type TierRole } from "../data/tierlist";
import { t, type Lang } from "../i18n";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const entries = await getTierListEntries(lang);

const roleLabelByValue: Record<TierRole, string> = {
    main_dps: t(lang, "tierlist.roleMainDps"),
    sub_dps: t(lang, "tierlist.roleSubDps"),
    support: t(lang, "tierlist.roleSupport")
};

const tierBadgeClass: Record<Tier, string> = {
    S: "bg-emerald-500 text-slate-900",
    A: "bg-sky-500 text-slate-900",
    B: "bg-amber-400 text-slate-900",
    C: "bg-slate-500 text-white"
};
---

<Layout title={t(lang, "tierlist.pageTitle")} lang={lang} description={t(lang, "tierlist.pageDescription")}>
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
        <header class="mb-8">
            <h1 class="text-4xl md:text-5xl font-bold text-white">{t(lang, "tierlist.title")}</h1>
            <p class="mt-3 text-slate-300 max-w-3xl">{t(lang, "tierlist.subtitle")}</p>
            <p class="mt-2 text-xs text-slate-400">{t(lang, "tierlist.disclaimer")}</p>
        </header>

        <div class="flex flex-wrap items-center gap-3 mb-8">
            <input
                id="tierlist-search"
                type="search"
                placeholder={t(lang, "tierlist.searchPlaceholder")}
                class="w-full sm:w-72 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-sm text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-yellow-400/60 focus:border-yellow-400/60"
            />

            <div class="inline-flex rounded-md shadow-sm" role="group" id="tier-filters">
                <button type="button" data-tier-filter="all" aria-pressed="true" class="px-3 py-2 text-sm font-medium border border-slate-600 rounded-l-lg bg-yellow-500 text-slate-900 hover:bg-yellow-400">
                    {t(lang, "tierlist.filterAllTiers")}
                </button>
                <button type="button" data-tier-filter="S" aria-pressed="false" class="px-3 py-2 text-sm font-medium border-t border-b border-slate-600 bg-slate-700 text-white hover:bg-slate-600">S</button>
                <button type="button" data-tier-filter="A" aria-pressed="false" class="px-3 py-2 text-sm font-medium border-t border-b border-slate-600 bg-slate-700 text-white hover:bg-slate-600">A</button>
                <button type="button" data-tier-filter="B" aria-pressed="false" class="px-3 py-2 text-sm font-medium border-t border-b border-slate-600 bg-slate-700 text-white hover:bg-slate-600">B</button>
                <button type="button" data-tier-filter="C" aria-pressed="false" class="px-3 py-2 text-sm font-medium border border-slate-600 rounded-r-lg bg-slate-700 text-white hover:bg-slate-600">C</button>
            </div>

            <div class="inline-flex rounded-md shadow-sm" role="group" id="role-filters">
                <button type="button" data-role-filter="all" aria-pressed="true" class="px-3 py-2 text-sm font-medium border border-slate-600 rounded-l-lg bg-yellow-500 text-slate-900 hover:bg-yellow-400">
                    {t(lang, "tierlist.filterAllRoles")}
                </button>
                <button type="button" data-role-filter="main_dps" aria-pressed="false" class="px-3 py-2 text-sm font-medium border-t border-b border-slate-600 bg-slate-700 text-white hover:bg-slate-600">{t(lang, "tierlist.roleMainDps")}</button>
                <button type="button" data-role-filter="sub_dps" aria-pressed="false" class="px-3 py-2 text-sm font-medium border-t border-b border-slate-600 bg-slate-700 text-white hover:bg-slate-600">{t(lang, "tierlist.roleSubDps")}</button>
                <button type="button" data-role-filter="support" aria-pressed="false" class="px-3 py-2 text-sm font-medium border border-slate-600 rounded-r-lg bg-slate-700 text-white hover:bg-slate-600">{t(lang, "tierlist.roleSupport")}</button>
            </div>
        </div>

        <div id="tierlist-grid" class="space-y-4">
            {entries.map((entry) => (
                <article
                    data-tierlist-item
                    data-name={entry.character.name}
                    data-tier={entry.tier}
                    data-role={entry.role}
                    class="grid grid-cols-[auto_1fr] md:grid-cols-[auto_auto_1fr_auto] items-center gap-3 bg-slate-800 border border-slate-700 rounded-xl p-3"
                >
                    <span class={`inline-flex items-center justify-center h-8 w-8 rounded-lg font-bold ${tierBadgeClass[entry.tier]}`}>
                        {entry.tier}
                    </span>

                    <img
                        src={entry.character.imageUrl}
                        alt={entry.character.name}
                        class="h-14 w-14 rounded-lg object-cover bg-slate-900 border border-slate-700"
                        loading="lazy"
                        referrerpolicy="no-referrer"
                        data-fallback={entry.character.fallbackImageUrl}
                        onerror="const fallback = this.getAttribute('data-fallback'); if (fallback && this.src !== fallback) { this.src = fallback; return; } this.onerror = null; this.src = '/favicon.svg';"
                    />

                    <div>
                        <h2 class="text-white font-semibold">{entry.character.name}</h2>
                        <p class="text-xs text-slate-400">{entry.character.elementLabel ?? entry.character.element} · {entry.character.weaponLabel ?? entry.character.weapon}</p>
                    </div>

                    <span class="justify-self-start md:justify-self-end text-xs px-2 py-1 rounded border border-slate-600 text-slate-300">
                        {roleLabelByValue[entry.role]}
                    </span>
                </article>
            ))}
        </div>
    </section>
</Layout>

<script>
    const tierButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-tier-filter]"));
    const roleButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-role-filter]"));
    const searchInput = document.querySelector<HTMLInputElement>("#tierlist-search");
    const items = Array.from(document.querySelectorAll<HTMLElement>("[data-tierlist-item]"));

    let activeTier = "all";
    let activeRole = "all";
    let activeQuery = "";

    const normalizeText = (value: string) =>
        value
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "");

    const setButtonState = (buttons: HTMLButtonElement[], dataAttr: "tierFilter" | "roleFilter", activeValue: string) => {
        for (const button of buttons) {
            const value = dataAttr === "tierFilter" ? (button.dataset.tierFilter ?? "all") : (button.dataset.roleFilter ?? "all");
            const isActive = value === activeValue;
            button.setAttribute("aria-pressed", String(isActive));
            button.classList.toggle("bg-yellow-500", isActive);
            button.classList.toggle("text-slate-900", isActive);
            button.classList.toggle("hover:bg-yellow-400", isActive);
            button.classList.toggle("bg-slate-700", !isActive);
            button.classList.toggle("text-white", !isActive);
            button.classList.toggle("hover:bg-slate-600", !isActive);
        }
    };

    const applyFilters = () => {
        for (const item of items) {
            const tier = item.dataset.tier ?? "";
            const role = item.dataset.role ?? "";
            const name = normalizeText(item.dataset.name ?? "");

            const tierMatch = activeTier === "all" || tier === activeTier;
            const roleMatch = activeRole === "all" || role === activeRole;
            const nameMatch = !activeQuery || name.includes(activeQuery);
            item.classList.toggle("hidden", !(tierMatch && roleMatch && nameMatch));
        }

        setButtonState(tierButtons, "tierFilter", activeTier);
        setButtonState(roleButtons, "roleFilter", activeRole);
    };

    for (const button of tierButtons) {
        button.addEventListener("click", () => {
            activeTier = button.dataset.tierFilter ?? "all";
            applyFilters();
        });
    }

    for (const button of roleButtons) {
        button.addEventListener("click", () => {
            activeRole = button.dataset.roleFilter ?? "all";
            applyFilters();
        });
    }

    searchInput?.addEventListener("input", () => {
        activeQuery = normalizeText(searchInput.value.trim());
        applyFilters();
    });
</script>
