---
import Layout from "../layouts/Layout.astro";
import { getTierListEntries, tierOrder, roleOrder, type Tier, type TierRole } from "../data/tierlist";
import { t, type Lang } from "../i18n";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const entries = await getTierListEntries(lang);

const roleLabelByValue: Record<TierRole, string> = {
    main_dps: t(lang, "tierlist.roleMainDps"),
    sub_dps: t(lang, "tierlist.roleSubDps"),
    support: t(lang, "tierlist.roleSupport")
};

const tierBadgeClass: Record<Tier, string> = {
    SS: "text-orange-200 border-orange-300/50 bg-orange-500/10",
    S: "text-yellow-200 border-yellow-300/50 bg-yellow-500/10",
    A: "text-emerald-200 border-emerald-300/50 bg-emerald-500/10",
    B: "text-sky-200 border-sky-300/50 bg-sky-500/10",
    C: "text-violet-200 border-violet-300/50 bg-violet-500/10",
    D: "text-fuchsia-200 border-fuchsia-300/50 bg-fuchsia-500/10"
};

const grouped = new Map<Tier, Map<TierRole, typeof entries>>();
for (const tier of tierOrder) {
    grouped.set(tier, new Map());
    for (const role of roleOrder) {
        grouped.get(tier)?.set(role, entries.filter((entry) => entry.tier === tier && entry.role === role));
    }
}
---

<Layout title={t(lang, "tierlist.pageTitle")} lang={lang} description={t(lang, "tierlist.pageDescription")}>
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
        <header class="mb-8">
            <h1 class="text-4xl md:text-5xl font-bold text-white">{t(lang, "tierlist.title")}</h1>
            <p class="mt-3 text-slate-300 max-w-3xl">{t(lang, "tierlist.subtitle")}</p>
        </header>

        <div class="mb-6 inline-flex rounded-xl border border-slate-700 bg-slate-800/80 p-1" role="tablist" aria-label="Tier list roles">
            {roleOrder.map((role, index) => (
                <button
                    type="button"
                    role="tab"
                    data-role-tab={role}
                    aria-selected={index === 0 ? "true" : "false"}
                    class={`px-4 py-2 text-sm font-semibold rounded-lg transition-colors ${index === 0 ? "bg-yellow-500 text-slate-900" : "text-slate-200 hover:bg-slate-700"}`}
                >
                    {roleLabelByValue[role]}
                </button>
            ))}
        </div>

        <div class="overflow-x-auto rounded-2xl border border-slate-700/70 bg-slate-900/70">
            <div class="min-w-225">
                <div class="grid grid-cols-[110px_1fr] bg-slate-800/80 border-b border-slate-700/80">
                    <div class="p-4"></div>
                    <div class="p-4 text-center text-sm font-semibold tracking-wide text-slate-100 uppercase" data-current-role-label>
                        {roleLabelByValue.main_dps}
                    </div>
                </div>

                {tierOrder.map((tier) => (
                    <div class="grid grid-cols-[110px_1fr] border-b border-slate-800 last:border-b-0">
                        <div class="flex items-center justify-center p-4 bg-slate-900/70">
                            <span class={`inline-flex items-center justify-center min-w-14 h-12 px-3 rounded-xl border text-2xl font-black tracking-tight ${tierBadgeClass[tier]}`}>
                                {tier}
                            </span>
                        </div>

                        <div class="p-4 border-l border-slate-800 min-h-40 flex items-center">
                            {roleOrder.map((role, index) => (
                                <div data-role-panel={role} class={index === 0 ? "w-full" : "hidden w-full"}>
                                    <div class="flex flex-wrap justify-center gap-4">
                                        {(grouped.get(tier)?.get(role) ?? []).map((entry) => (
                                            <article class="w-24 sm:w-28">
                                                <img
                                                    src={entry.character.imageUrl}
                                                    alt={entry.character.name}
                                                    class="w-full aspect-square rounded-lg object-cover bg-slate-900 border border-slate-700"
                                                    loading="lazy"
                                                    decoding="async"
                                                    referrerpolicy="no-referrer"
                                                    data-fallback={entry.character.fallbackImageUrl}
                                                    onerror="const fallback = this.getAttribute('data-fallback'); if (fallback && this.src !== fallback) { this.src = fallback; return; } this.onerror = null; this.src = '/favicon.svg';"
                                                />
                                                <p class="mt-1.5 text-xs leading-tight text-slate-200 text-center truncate">{entry.character.name}</p>
                                            </article>
                                        ))}
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>
</Layout>

<script>
    const initTierRoleTabs = () => {
        const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-role-tab]"));
        const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-role-panel]"));
        const roleLabel = document.querySelector<HTMLElement>("[data-current-role-label]");

        if (!tabs.length || !panels.length) {
            return;
        }

        const setActiveRole = (role: string) => {
            for (const tab of tabs) {
                const isActive = tab.dataset.roleTab === role;
                tab.setAttribute("aria-selected", String(isActive));
                tab.classList.toggle("bg-yellow-500", isActive);
                tab.classList.toggle("text-slate-900", isActive);
                tab.classList.toggle("text-slate-200", !isActive);
                tab.classList.toggle("hover:bg-slate-700", !isActive);
            }

            for (const panel of panels) {
                panel.classList.toggle("hidden", panel.dataset.rolePanel !== role);
            }

            const activeTab = tabs.find((tab) => tab.dataset.roleTab === role);
            if (activeTab && roleLabel) {
                roleLabel.textContent = activeTab.textContent?.trim() ?? "";
            }
        };

        for (const tab of tabs) {
            tab.addEventListener("click", () => {
                setActiveRole(tab.dataset.roleTab ?? "main_dps");
            });
        }

        setActiveRole("main_dps");
    };

    initTierRoleTabs();
    document.addEventListener("astro:page-load", initTierRoleTabs);
</script>
